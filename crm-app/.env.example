# Skopíruj tento súbor ako .env.local a vyplň hodnoty

# Databáza
DATABASE_URL=postgresql://crm:crm_secret@localhost:5432/crm_db

# PostgreSQL (pre docker-compose)
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_secret
POSTGRES_DB=crm_db

# Autentifikácia
SESSION_SECRET=GENERUJ_NAHODNY_KLUC_BASE64

# Aplikácia
NEXT_PUBLIC_APP_URL=https://crm.domterm.sk

# ── Google Calendar integrácia (nepovinné) ─────────────────────────
# Ak nevyplníš, obhliadky sa ukladajú do DB bez synchronizácie s Google Kalendárom.
#
# Postup nastavenia (jednorazový, ~10 minút):
#   1. Google Cloud Console → APIs & Services → Enable "Google Calendar API"
#   2. Credentials → Create Credentials → OAuth 2.0 Client ID (typ: Web application)
#      Authorized redirect URIs: https://developers.google.com/oauthplayground
#   3. Otvor https://developers.google.com/oauthplayground
#      → Settings (⚙) → "Use your own OAuth credentials" → vlož Client ID + Secret
#      → Scope: https://www.googleapis.com/auth/calendar → Authorize → Exchange → kopíruj Refresh token
#   4. Vytvor firemný Google Kalendár a skopíruj jeho ID (Nastavenia → Integrácia kalendára)
#
GOOGLE_CLIENT_ID=tvoj-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tvoj-secret
GOOGLE_REFRESH_TOKEN=1//tvoj-refresh-token
GOOGLE_CALENDAR_ID=tvoj-firemny-kalendar@group.calendar.google.com
